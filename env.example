# NodusAI MCP Server — Environment Variables
# Copy this to .env for local dev (never commit .env)
# Set these as environment variables in Railway / Render / Fly.io

# ── Required ───────────────────────────────────────────────────────────────────
# URL of the NodusAI oracle API
NODUSAI_API_BASE=https://nodusai.app

# HTTP port (Railway sets this automatically)
PORT=3000

# ── Optional ───────────────────────────────────────────────────────────────────
# Set to "true" to use mock oracle responses (dev/testing only)
# NODUSAI_MOCK=true
